@page "/Asignaciones/Create"
@rendermode InteractiveServer
@inject AsignacionesService asignacionesService
@inject NavigationManager navManager
@inject ToastService toastService

<PageTitle>Crear Asignacion</PageTitle>

<EditForm Model="asignacion" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container">
        <div class="card">
            <div class="card-header">
                <h3>Nueva Asignación de Puntos</h3>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Fecha</label>
                    <InputDate @bind-Value="asignacion.Fecha" class="form-control" />
                    <ValidationMessage For="@(() => asignacion.Fecha)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Estudiante</label>
                    <InputSelect @bind-Value="asignacion.EstudianteId" class="form-select">
                        <option value="0">-- Seleccione --</option>
                        @foreach (var e in estudiantes)
                        {
                            <option value="@e.EstudianteId">@e.Nombres</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => asignacion.EstudianteId)" />
                </div>

                <hr />
                <h5>Detalle de Puntos</h5>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Tipo de Punto</label>
                        <select class="form-select"
                                @bind="nuevoTipoId"
                                @bind:after="AlSeleccionarTipo">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var t in tiposActivos)
                            {
                                <option value="@t.TipoId">@t.Nombre (@t.ValorPuntos pts)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Puntos</label>
                        <input type="number" class="form-control" @bind="nuevaCantidad" readonly />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-success w-100" @onclick="AgregarDetalle">
                            + Agregar
                        </button>
                    </div>
                </div>

                @if (mostrarErrorDetalle)
                {
                    <div class="alert alert-danger">Debe agregar al menos un tipo de punto.</div>
                }

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Tipo de Punto</th>
                            <th>Puntos</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in asignacion.Detalle)
                        {
                            <tr>
                                <td>@tiposActivos.FirstOrDefault(t => t.TipoId == d.TipoPuntoId)?.Nombre</td>
                                <td>@d.CantidadPuntos</td>
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm"
                                            @onclick="() => EliminarDetalle(d)">
                                        Quitar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-footer">
                <div class="float-end">
                    <a href="/Asignaciones/Index" class="btn btn-secondary">Volver</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public AsignacionesPuntos asignacion = new();
    public List<Estudiantes> estudiantes = new();
    public List<TiposPuntos> tiposActivos = new();
    private int nuevoTipoId = 0;
    private int nuevaCantidad = 0;
    private bool mostrarErrorDetalle = false;

    protected override async Task OnInitializedAsync()
    {
        estudiantes = await asignacionesService.ListarEstudiantes();
        tiposActivos = await asignacionesService.ListarTiposActivos();
    }

    private void AlSeleccionarTipo()
    {
        var tipo = tiposActivos.FirstOrDefault(t => t.TipoId == nuevoTipoId);
        nuevaCantidad = tipo?.ValorPuntos ?? 0;
    }

    private void AgregarDetalle()
    {
        if (nuevoTipoId == 0) return;
        asignacion.Detalle.Add(new DetalleAsignacion
        {
            TipoPuntoId = nuevoTipoId,
            CantidadPuntos = nuevaCantidad
        });
        nuevoTipoId = 0;
        nuevaCantidad = 0;
        mostrarErrorDetalle = false;
    }

    private void EliminarDetalle(DetalleAsignacion detalle)
    {
        asignacion.Detalle.Remove(detalle);
    }

    private async Task Guardar()
    {
        if (asignacion.Detalle.Count == 0)
        {
            mostrarErrorDetalle = true;
            return;
        }

        if (await asignacionesService.Guardar(asignacion))
        {
            toastService.Notify(new(ToastType.Success, "Exito", "La asignación se guardó correctamente."));
            navManager.NavigateTo("/Asignaciones/Index");
        }
        else
        {
            toastService.Notify(new(ToastType.Danger, "Error", "No se pudo guardar la asignacion."));
        }
    }
}