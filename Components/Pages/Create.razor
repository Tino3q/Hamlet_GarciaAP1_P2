@page "/NavesEspaciales/Create"
@rendermode InteractiveServer
@inject NavesEspacialesService navesService
@inject NavigationManager navManager
@inject ToastService toastService

<PageTitle>Crear Nave</PageTitle>

<EditForm Model="nave" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container">
        <div class="card">
            <div class="card-header">
                <h3>Nueva Nave Espacial</h3>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <InputText @bind-Value="nave.Nombre" class="form-control" />
                    <ValidationMessage For="@(() => nave.Nombre)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Modelo</label>
                    <InputText @bind-Value="nave.Modelo" class="form-control" />
                    <ValidationMessage For="@(() => nave.Modelo)" />
                </div>
            </div>

            <div class="card-footer">
                <div class="float-end">
                    <a href="/NavesEspaciales/Index" class="btn btn-secondary">Volver</a>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public NavesEspaciales nave = new();

    private async Task Guardar()
    {
        if (await navesService.Guardar(nave))
        {
            toastService.Notify(new(ToastType.Success, "Éxito", "La nave se guardó correctamente."));
            navManager.NavigateTo("/NavesEspaciales/Index");
        }
        else
        {
            toastService.Notify(new(ToastType.Danger, "Error", "No se pudo guardar la nave."));
        }
    }
}