@page "/Asignaciones/Index"
@rendermode InteractiveServer
@inject AsignacionesService asignacionesService
@inject ToastService toastService

<PageTitle>Listado de Asignaciones</PageTitle>

<div class="container">
    <div class="card">
        <div class="card-header d-flex justify-content-between">
            <h3>Listado de Asignaciones de Puntos</h3>
            <a href="/Asignaciones/Create" class="btn btn-primary">
                Nueva Asignación
            </a>
        </div>

        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Estudiante:</label>
                    <select class="form-select" @bind="EstudianteFiltro">
                        <option value="0"> Filtrar Todo </option>
                        @foreach (var e in estudiantes)
                        {
                            <option value="@e.EstudianteId">@e.Nombres</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Desde:</label>
                    <input type="date" class="form-control" @bind="FechaDesde" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Hasta:</label>
                    <input type="date" class="form-control" @bind="FechaHasta" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-secondary me-2" @onclick="Buscar">
                        Buscar
                    </button>
                    <button class="btn btn-dark" @onclick="Restablecer">
                        Restablecer
                    </button>
                </div>
            </div>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Estudiante</th>
                        <th>Total Puntos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asignacion in asignaciones)
                    {
                        <tr>
                            <td>@asignacion.IdAsignacion</td>
                            <td>@asignacion.Fecha.ToShortDateString()</td>
                            <td>@asignacion.Estudiante?.Nombres</td>
                            <td>@asignacion.TotalPuntos</td>
                            <td>
                                <a href="/Asignaciones/Edit/@asignacion.IdAsignacion" class="btn btn-primary btn-sm">
                                    Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-secondary fw-bold">
                        <td colspan="3">Total de registros: @asignaciones.Count</td>
                        <td colspan="2">Total de puntos: @asignaciones.Sum(a => a.TotalPuntos)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@code {
    public List<AsignacionesPuntos> asignaciones = new();
    public List<Estudiantes> estudiantes = new();
    public int EstudianteFiltro { get; set; } = 0;
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }

    protected override async Task OnInitializedAsync()
    {
        estudiantes = await asignacionesService.ListarEstudiantes();
        await Buscar();
    }

    private async Task Buscar()
    {
        asignaciones = await asignacionesService.Listar(a =>
            (EstudianteFiltro == 0 || a.EstudianteId == EstudianteFiltro) &&
            (!FechaDesde.HasValue || a.Fecha >= FechaDesde.Value) &&
            (!FechaHasta.HasValue || a.Fecha <= FechaHasta.Value)
        );

        if (asignaciones.Count == 0)
            toastService.Notify(new(ToastType.Info, "Informacion", "No se encontraron asignaciones."));
    }

    private async Task Restablecer()
    {
        EstudianteFiltro = 0;
        FechaDesde = null;
        FechaHasta = null;
        await Buscar();
    }
}